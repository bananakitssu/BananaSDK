{
  "name": "@bananacool467/authtics-host",
  "version": "0.1.7",
  "description": "Authtics Host, A Next.js-inspired SSR framework for Node.js with TypeScript and JSX support.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "authtics": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node dist/index.js",
    "playgroundTest": "npm run build && cd playground && node --experimental-strip-types index.ts",
    "playgroundTest2": "npm run build && cd playground2 && node --experimental-strip-types index.ts"
  },
  "keywords": [
    "authtics",
    "host",
    "server-side-rendering",
    "ssr",
    "framework",
    "nodejs",
    "typescript",
    "react",
    "tsx",
    "jsx",
    "html",
    "js",
    "lightweight",
    "hot-reload",
    "dev",
    "developer",
    "HostJS",
    "Host.js",
    "website"
  ],
  "author": "bananacool467",
  "license": "MIT",
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "esbuild": "^0.27.3",
    "jiti": "^2.6.1",
    "lucide-react": "^0.577.0",
    "prismjs": "^1.30.0"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/babel__core": "^7.20.5",
    "@types/babel__preset-env": "^7.10.0"
  }
}
